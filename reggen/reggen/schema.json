{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reggen/schema/v0.json",
  "title": "reggen register-map specification (v0)",
  "type": "object",
  "additionalProperties": false,
  "required": ["block", "registers"],
  "properties": {
    "block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name":        { "$ref": "#/$defs/identifier" },
        "description": { "type": "string" },
        "data_width":  { "type": "integer", "enum": [8, 16, 32, 64], "default": 32 },
        "addr_width":  { "type": "integer", "minimum": 1, "maximum": 64, "default": 32 },
        "base_address":{ "$ref": "#/$defs/uint" }
      }
    },
    "registers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/register" }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
      "description": "Valid C/SV identifier — usable as a codegen symbol."
    },
    "uint": {
      "description": "Non-negative integer; YAML may write it as decimal or 0x-hex string.",
      "oneOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "string", "pattern": "^0[xX][0-9a-fA-F]+$" }
      ]
    },
    "access": {
      "type": "string",
      "enum": ["RW", "RO", "WO", "W1C", "W1S", "RW1C", "RW1S", "RC"],
      "description": "Field access policy. RW read-write; RO read-only (HW writes); WO write-only; W1C write-1-to-clear; W1S write-1-to-set; RW1C/RW1S read + write-1-to-(clear|set); RC read-clears."
    },
    "register": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "offset"],
      "properties": {
        "name":        { "$ref": "#/$defs/identifier" },
        "description": { "type": "string" },
        "offset":      { "$ref": "#/$defs/uint" },
        "width":       { "type": "integer", "enum": [8, 16, 32, 64] },
        "access":      { "$ref": "#/$defs/access" },
        "reset":       { "$ref": "#/$defs/uint" },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/field" }
        }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "bits"],
      "properties": {
        "name":        { "$ref": "#/$defs/identifier" },
        "description": { "type": "string" },
        "bits": {
          "type": "string",
          "pattern": "^[0-9]+(:[0-9]+)?$",
          "description": "Bit position 'N' or inclusive range 'MSB:LSB', e.g. '7:0' or '5'."
        },
        "access":      { "$ref": "#/$defs/access" },
        "reset":       { "$ref": "#/$defs/uint" },
        "enum": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "value"],
            "properties": {
              "name":        { "$ref": "#/$defs/identifier" },
              "description": { "type": "string" },
              "value":       { "$ref": "#/$defs/uint" }
            }
          }
        }
      }
    }
  }
}
