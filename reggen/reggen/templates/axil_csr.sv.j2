`default_nettype none

module {{ module }} #(
    parameter int DATA_WIDTH = {{ data_width }},
    parameter int ADDR_WIDTH = {{ addr_width }}
) (
    input  wire                    s_axi_aclk,
    input  wire                    s_axi_aresetn,

    // Write address channel
    input  wire [ADDR_WIDTH-1:0]   s_axi_awaddr,
    input  wire                    s_axi_awvalid,
    output wire                    s_axi_awready,
    // Write data channel
    input  wire [DATA_WIDTH-1:0]   s_axi_wdata,
    input  wire [DATA_WIDTH/8-1:0] s_axi_wstrb,
    input  wire                    s_axi_wvalid,
    output wire                    s_axi_wready,
    // Write response channel
    output reg  [1:0]              s_axi_bresp,
    output reg                     s_axi_bvalid,
    input  wire                    s_axi_bready,
    // Read address channel
    input  wire [ADDR_WIDTH-1:0]   s_axi_araddr,
    input  wire                    s_axi_arvalid,
    output wire                    s_axi_arready,
    // Read data channel
    output reg  [DATA_WIDTH-1:0]   s_axi_rdata,
    output reg  [1:0]              s_axi_rresp,
    output reg                     s_axi_rvalid,
    input  wire                    s_axi_rready{{ "," if ports }}
{# ---- design-facing register ports ---- #}
{% for p in ports %}
    {{ p.dir }} {{ "%-8s" | format(p.vslice) }} {{ p.name }}{{ "," if not loop.last }}  // {{ p.comment }}
{% endfor %}
);

    // ---- register byte offsets ----
{% for r in registers %}
    localparam [ADDR_WIDTH-1:0] ADDR_{{ r.name }} = 'h{{ '%X' % r.offset }};
{% endfor %}

    // ---- AXI-Lite handshake (fully registered; no comb VALID/READY path) ----
    reg                    axi_awready, axi_wready, axi_arready;
    reg [ADDR_WIDTH-1:0]   axi_awaddr, axi_araddr;
    reg                    aw_en;

    assign s_axi_awready = axi_awready;
    assign s_axi_wready  = axi_wready;
    assign s_axi_arready = axi_arready;

    // Write address / data accept: require both AWVALID and WVALID present.
    always @(posedge s_axi_aclk) begin
        if (!s_axi_aresetn) begin
            axi_awready <= 1'b0;
            axi_wready  <= 1'b0;
            aw_en       <= 1'b1;
            axi_awaddr  <= '0;
        end else begin
            if (!axi_awready && s_axi_awvalid && s_axi_wvalid && aw_en) begin
                axi_awready <= 1'b1;
                axi_wready  <= 1'b1;
                axi_awaddr  <= s_axi_awaddr;
                aw_en       <= 1'b0;
            end else if (s_axi_bready && s_axi_bvalid) begin
                aw_en       <= 1'b1;
                axi_awready <= 1'b0;
                axi_wready  <= 1'b0;
            end else begin
                axi_awready <= 1'b0;
                axi_wready  <= 1'b0;
            end
        end
    end

    // A single-cycle write strobe: the cycle both ready and both valid hold.
    wire wr_en = axi_awready && s_axi_awvalid && axi_wready && s_axi_wvalid;
    // Per-bit write enable expanded from the byte strobes.
    wire [DATA_WIDTH-1:0] wr_be = {{ wstrb_concat }};

    // Write response.
    always @(posedge s_axi_aclk) begin
        if (!s_axi_aresetn) begin
            s_axi_bvalid <= 1'b0;
            s_axi_bresp  <= 2'b00;
        end else if (wr_en && !s_axi_bvalid) begin
            s_axi_bvalid <= 1'b1;
            s_axi_bresp  <= 2'b00;               // OKAY
        end else if (s_axi_bready && s_axi_bvalid) begin
            s_axi_bvalid <= 1'b0;
        end
    end

    // Read address accept.
    always @(posedge s_axi_aclk) begin
        if (!s_axi_aresetn) begin
            axi_arready <= 1'b0;
            axi_araddr  <= '0;
        end else if (!axi_arready && s_axi_arvalid) begin
            axi_arready <= 1'b1;
            axi_araddr  <= s_axi_araddr;
        end else begin
            axi_arready <= 1'b0;
        end
    end

    wire rd_en = axi_arready && s_axi_arvalid && !s_axi_rvalid;

    // ---- per-field storage & update logic ----
{% for r in registers %}
{% for f in r.fields %}
{% if f.category == 'rw' or f.category == 'wo' %}
    reg {{ f.vslice }} {{ f.q }};
    always @(posedge s_axi_aclk) begin
        if (!s_axi_aresetn)
            {{ f.q }} <= {{ f.width }}'h{{ '%X' % f.reset }};
        else if (wr_en && axi_awaddr == ADDR_{{ r.name }})
            {{ f.q }} <= ({{ f.q }} & ~wr_be{{ f.slice }}) | (s_axi_wdata{{ f.slice }} & wr_be{{ f.slice }});
    end
    always @(*) {{ f.port_o }} = {{ f.q }};

{% elif f.category == 'w1c' %}
    reg {{ f.vslice }} {{ f.q }};
    always @(posedge s_axi_aclk) begin
        if (!s_axi_aresetn)
            {{ f.q }} <= {{ f.width }}'h{{ '%X' % f.reset }};
        else
            // HW set wins so events are never lost; SW write-1 clears.
            {{ f.q }} <= ((wr_en && axi_awaddr == ADDR_{{ r.name }})
                          ? ({{ f.q }} & ~(s_axi_wdata{{ f.slice }} & wr_be{{ f.slice }}))
                          : {{ f.q }}) | {{ f.port_set }};
    end
    always @(*) {{ f.port_o }} = {{ f.q }};

{% elif f.category == 'w1s' %}
    reg {{ f.vslice }} {{ f.q }};
    always @(posedge s_axi_aclk) begin
        if (!s_axi_aresetn)
            {{ f.q }} <= {{ f.width }}'h{{ '%X' % f.reset }};
        else
            // HW clear wins; SW write-1 sets.
            {{ f.q }} <= ((wr_en && axi_awaddr == ADDR_{{ r.name }})
                          ? ({{ f.q }} | (s_axi_wdata{{ f.slice }} & wr_be{{ f.slice }}))
                          : {{ f.q }}) & ~{{ f.port_clr }};
    end
    always @(*) {{ f.port_o }} = {{ f.q }};

{% elif f.category == 'rc' %}
    reg {{ f.vslice }} {{ f.q }};
    always @(posedge s_axi_aclk) begin
        if (!s_axi_aresetn)
            {{ f.q }} <= {{ f.width }}'h{{ '%X' % f.reset }};
        else
            // A SW read clears; HW set wins.
            {{ f.q }} <= ((rd_en && axi_araddr == ADDR_{{ r.name }}) ? {{ f.width }}'h0 : {{ f.q }}) | {{ f.port_set }};
    end
    always @(*) {{ f.port_o }} = {{ f.q }};

{% endif %}
{% endfor %}
{% endfor %}
    // ---- read data mux ----
    reg [DATA_WIDTH-1:0] rd_data;
    always @(*) begin
        rd_data = {DATA_WIDTH{1'b0}};
        case (axi_araddr)
{% for r in registers %}
            ADDR_{{ r.name }}: begin
{% for f in r.fields %}
{% if f.read_source %}
                rd_data{{ f.slice }} = {{ f.read_source }};
{% endif %}
{% endfor %}
            end
{% endfor %}
            default: rd_data = {DATA_WIDTH{1'b0}};
        endcase
    end

    always @(posedge s_axi_aclk) begin
        if (!s_axi_aresetn) begin
            s_axi_rvalid <= 1'b0;
            s_axi_rresp  <= 2'b00;
            s_axi_rdata  <= '0;
        end else if (rd_en) begin
            s_axi_rvalid <= 1'b1;
            s_axi_rresp  <= 2'b00;               // OKAY
            s_axi_rdata  <= rd_data;
        end else if (s_axi_rvalid && s_axi_rready) begin
            s_axi_rvalid <= 1'b0;
        end
    end

endmodule
`default_nettype wire
