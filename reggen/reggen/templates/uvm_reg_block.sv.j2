`ifndef {{ pkg | upper }}_SV
`define {{ pkg | upper }}_SV

package {{ pkg }};

    import uvm_pkg::*;
    `include "uvm_macros.svh"

{% for r in registers %}
    // -------------------------------------------------------------------------
    // {{ r.name }} @ 0x{{ '%X' % r.offset }}
    // -------------------------------------------------------------------------
    class {{ r.class_name }} extends uvm_reg;
        `uvm_object_utils({{ r.class_name }})

{% for f in r.fields %}
        rand uvm_reg_field {{ f.name }};
{% endfor %}

        function new(string name = "{{ r.class_name }}");
            super.new(name, {{ r.width }}, UVM_NO_COVERAGE);
        endfunction

        virtual function void build();
{% for f in r.fields %}
            {{ f.name }} = uvm_reg_field::type_id::create("{{ f.name }}");
            // configure(parent, size, lsb, access, volatile, reset, has_reset, is_rand, individually_accessible)
            {{ f.name }}.configure(this, {{ f.size }}, {{ f.lsb }}, "{{ f.access }}", {{ f.volatile }}, {{ f.size }}'h{{ '%X' % f.reset }}, {{ f.has_reset }}, {{ f.is_rand }}, {{ f.individually_accessible }});
{% endfor %}
        endfunction

    endclass

{% endfor %}
    // -------------------------------------------------------------------------
    // Register block
    // -------------------------------------------------------------------------
    class {{ block_class }} extends uvm_reg_block;
        `uvm_object_utils({{ block_class }})

{% for r in registers %}
        rand {{ r.class_name }} {{ r.name }};
{% endfor %}
        uvm_reg_map default_map;

        function new(string name = "{{ block_class }}");
            super.new(name, UVM_NO_COVERAGE);
        endfunction

        virtual function void build();
            default_map = create_map("default_map", 'h{{ '%X' % base_address }}, {{ data_bytes }}, UVM_LITTLE_ENDIAN);

{% for r in registers %}
            {{ r.name }} = {{ r.class_name }}::type_id::create("{{ r.name }}");
            {{ r.name }}.configure(this, null, "");
            {{ r.name }}.build();
            default_map.add_reg({{ r.name }}, 'h{{ '%X' % r.offset }}, "{{ r.rights }}");

{% endfor %}
            lock_model();
        endfunction

    endclass

endpackage

`endif // {{ pkg | upper }}_SV
